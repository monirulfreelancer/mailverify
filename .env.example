# mailverify configuration — copy to .env and adjust.
# (Loading .env into the process is up to your runtime; e.g. `node --env-file=.env server.js`
#  on Node 20+, or a process manager. The app reads plain process.env.)

# --- HTTP server ---
# Port the Express API listens on.
PORT=3000

# Comma-separated list of allowed API keys for the X-API-Key header.
# If left empty, authentication is DISABLED (all requests allowed) — dev only.
API_KEYS=devkey1,devkey2

# --- SMTP probe (read by the engine, src/engine/smtp.js) ---
# Domain announced in the EHLO command.
SMTP_HELO_DOMAIN=verify.mailverify.app

# Address used in MAIL FROM during the probe (no mail is ever actually sent).
SMTP_FROM_ADDRESS=probe@verify.mailverify.app

# Per-connection SMTP timeout in milliseconds.
SMTP_TIMEOUT_MS=10000

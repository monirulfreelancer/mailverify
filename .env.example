# mailverify configuration — copy to .env and adjust.
# (Loading .env into the process is up to your runtime; e.g. `node --env-file=.env server.js`
#  on Node 20+, or a process manager / Coolify env settings. The app reads plain process.env.)

# --- HTTP server ---
# Port the Express API listens on. The server binds 0.0.0.0 so it is reachable
# from outside the container.
PORT=3000

# --- Database (PostgreSQL) ---
# Connection string for node-postgres. When set, API keys, credits, results and
# the domain cache are read/written here, and auth becomes database-backed.
# When UNSET, the app runs in degraded mode: no persistence, no credits, and
# auth falls back to the API_KEYS list below.
# Example:
# DATABASE_URL=postgres://mailverify:secret@localhost:5432/mailverify

# Optional: max connections in the pg pool (default 10).
# PG_POOL_MAX=10

# --- Redis (reserved for the queue, Chunk 4B) ---
# Not used yet. Document/leave empty for now; the background job queue will read it.
# REDIS_URL=redis://localhost:6379

# --- Auth (legacy / fallback) ---
# Comma-separated list of allowed API keys for the X-API-Key header.
# Used ONLY as a fallback when DATABASE_URL is unset. With a database configured,
# real keys live in the api_keys table (create them via `npm run seed`) and this
# list is ignored. If empty AND there is no database, auth is DISABLED — dev only.
API_KEYS=

# --- Migrations ---
# Set to "true" on the FIRST deploy to auto-create tables on boot (requires
# DATABASE_URL). Remove it (or set anything else) on subsequent deploys.
RUN_MIGRATIONS=false

# --- SMTP probe (read by the engine, src/engine/smtp.js) ---
# Domain announced in the EHLO command.
SMTP_HELO_DOMAIN=verify.mailverify.app

# Address used in MAIL FROM during the probe (no mail is ever actually sent).
SMTP_FROM_ADDRESS=probe@verify.mailverify.app

# Per-connection SMTP timeout in milliseconds.
SMTP_TIMEOUT_MS=10000
